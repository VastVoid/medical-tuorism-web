<svg xmlns="http://www.w3.org/2000/svg" width="600" height="400">
  <defs>
    <linearGradient id="plastGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FF6B6B;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#FF5252;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="600" height="400" fill="url(#plastGrad)"/>
  <text x="50%" y="45%" font-family="Arial, sans-serif" font-size="80" fill="white" text-anchor="middle">✨</text>
  <text x="50%" y="65%" font-family="Arial, sans-serif" font-size="24" fill="white" text-anchor="middle">Пластическая хирургия</text>
</svg>
